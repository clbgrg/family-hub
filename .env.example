# Family Hub configuration. Copy to .env and fill in. NEVER commit .env.
#   cp .env.example .env

# REQUIRED — Postgres password. There is no default; the app won't start without it.
# Generate a strong one:  openssl rand -base64 24
POSTGRES_PASSWORD=

# REQUIRED — secret that seals login session cookies (min 32 chars). No default.
# Changing it logs everyone out. Generate one:  openssl rand -base64 36
NUXT_SESSION_PASSWORD=

# Timezone (IANA name), used by the calendar. Default: America/Los_Angeles
NUXT_PUBLIC_TZ=America/Los_Angeles

# App log level: error | warn | info | debug. Default: warn
NUXT_PUBLIC_LOG_LEVEL=warn

# SSRF guard: iCal calendar URLs must point at PUBLIC hosts (Apple/Google
# feeds). Set true only if your family hosts its own calendar feed on the LAN
# (e.g. a Home Assistant .ics) — it lets the server fetch private addresses.
FH_ALLOW_PRIVATE_URLS=false

# LAN address phones should use to reach the app — shown as the QR code in
# Settings → Network & Access. The Docker container can't detect the host's
# LAN IP itself, so set this to your Pi/host's address:
#   APP_PUBLIC_URL=http://192.168.1.50:3000
APP_PUBLIC_URL=

# Host interface the app binds to:
#   0.0.0.0   = reachable from phones/tablets on your WiFi (default; needed on the Pi)
#   127.0.0.1 = localhost only (hardened; pair with a reverse proxy or Tailscale)
APP_BIND=0.0.0.0

# Prebuilt-image deploy only (docker-compose.prod.yml): which GHCR image tag to
# run. Leave as `latest` for auto-updates on each release; pin (e.g. 2026.6.0)
# to stop Watchtower from updating. See docs/deployment.md.
FH_IMAGE_TAG=latest

# Backups (the `backup` sidecar): how often to dump, and how many to keep.
# Defaults: daily, last 7. Dumps land in ./backups (gitignored).
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
