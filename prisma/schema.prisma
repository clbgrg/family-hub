// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  avatar    String?
  color     String?
  todoOrder Int      @default(0)
  // Family Hub auth (single-tenant: one family per deployment).
  // role gates admin-only actions; pinHash is null until an admin sets a PIN.
  role      Role     @default(MEMBER)
  pinHash   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  todoColumn TodoColumn?
  calendarEvents CalendarEventUser[]
  assignedChores   Chore[]           @relation("ChoreAssignee")
  choreCompletions ChoreCompletion[] @relation("ChoreCompletionUser")
  badges           UserBadge[]
  mealsCooking     Meal[]            @relation("MealCook")
  messages         Message[]

  @@map("users")
}

model TodoColumn {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos     Todo[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("todo_columns")
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  priority    Priority @default(MEDIUM)
  dueDate     DateTime?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  todoColumnId String?
  todoColumn   TodoColumn? @relation(fields: [todoColumnId], references: [id], onDelete: Cascade)

  recurringGroupId  String?
  rrule             Json?

  @@map("todos")
}

model ShoppingList {
  id        String            @id @default(cuid())
  name      String
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  items ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id       String  @id @default(cuid())
  name     String
  quantity Int     @default(1)
  unit     String?
  checked  Boolean @default(false)
  notes    String?
  order    Int     @default(0)

  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  @@map("shopping_list_items")
}

model Integration {
  id        String   @id @default(cuid())
  name      String
  type      String
  service   String
  apiKey    String?
  baseUrl   String?
  icon      String?
  enabled   Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
  @@map("integrations")
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  start       DateTime
  end         DateTime
  allDay      Boolean  @default(false)
  color       Json?
  location    String?
  ical_event  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users CalendarEventUser[]

  @@map("calendar_events")
}

model CalendarEventUser {
  id             String        @id @default(cuid())
  calendarEventId String
  userId         String
  createdAt      DateTime      @default(now())

  calendarEvent CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([calendarEventId, userId])
  @@map("calendar_event_users")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Role {
  ADMIN
  MEMBER
}

// A chore template assigned to one family member. Completion is tracked as
// ChoreCompletion rows (one per day for recurring chores), so "reset" is
// implicit each new day — no cron — and history is kept for streaks/points.
model Chore {
  id          String          @id @default(cuid())
  title       String
  description String?
  points      Int             @default(0)
  recurrence  ChoreRecurrence @default(DAILY)
  daysOfWeek  Int[]           @default([]) // for WEEKLY: 0=Sun .. 6=Sat
  order       Int             @default(0)
  active      Boolean         @default(true)

  // Every chore has exactly one owner (the points recipient).
  assigneeId String
  assignee   User   @relation("ChoreAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)

  completions ChoreCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chores")
}

// One completion of a chore on a given local day. userId is the chore's
// assignee (who earns the points), set server-side — not the session user,
// so an admin checking off a kid's chore credits the kid. points snapshots
// the chore's value at completion time.
model ChoreCompletion {
  id          String   @id @default(cuid())
  choreId     String
  chore       Chore    @relation(fields: [choreId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("ChoreCompletionUser", fields: [userId], references: [id], onDelete: Cascade)
  localDate   String // client's local date "YYYY-MM-DD"
  points      Int
  completedAt DateTime @default(now())

  @@unique([choreId, localDate]) // a chore is completed at most once per day
  @@map("chore_completions")
}

enum ChoreRecurrence {
  ONCE
  DAILY
  WEEKLY
}

// A planned meal in the weekly grid: one per (date, slot). Family-wide (not
// per-member) — the family eats together; cook is just an optional attribute.
// Free-text for now (title/notes/ingredients); structured recipes are a later phase.
model Meal {
  id          String   @id @default(cuid())
  date        String // client-local "YYYY-MM-DD"
  slot        MealSlot
  title       String
  notes       String?
  ingredients String? // free-text, one item per line — used to generate groceries
  time        String? // optional "HH:MM" (dinner schedule)
  cookId      String?
  cook        User?    @relation("MealCook", fields: [cookId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, slot])
  @@map("meals")
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
}

// A sticky-note on the family message board. Any member can post; the author
// or an admin can delete. Auto-expires by filtering on expiresAt (no cron).
model Message {
  id        String   @id @default(cuid())
  body      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime // createdAt + 7 days (stored so expiry is configurable later)

  @@index([expiresAt])
  @@map("messages")
}

// A badge a user has earned. Badge *types* are code-defined (server/utils/badges.ts);
// this records which user earned which, and when. Permanent once earned.
model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey String
  earnedAt DateTime @default(now())

  @@unique([userId, badgeKey])
  @@map("user_badges")
}
