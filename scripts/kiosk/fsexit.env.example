# Family Hub — exit-fullscreen button config.
# Copy to ~/.config/family-hub/fsexit.env and edit. Sourced (POSIX sh) by the
# kiosk .xinitrc and read by fullscreen-exit.py.

# Which corner the button sits in: top-left | top-right | bottom-left | bottom-right
FSEXIT_CORNER=top-right

# Button size, in pixels.
FSEXIT_SIZE=64

# Gap from the screen edge, in pixels.
FSEXIT_MARGIN=16

# Opacity when idle (0..1) — semi-transparent so it doesn't distract.
FSEXIT_OPACITY_IDLE=0.35

# Opacity when touched/hovered (0..1) — fully visible.
FSEXIT_OPACITY_ACTIVE=1.0

# Key(s) xdotool sends on tap. "Escape" leaves page fullscreen (YouTube, HTML5
# video, PDF, F11) without exiting chromium --kiosk.
FSEXIT_KEY=Escape

# Button glyph/text. Any character your kiosk font renders (e.g. ✕ ⤢ ⛶ or "Exit").
FSEXIT_LABEL=✕
