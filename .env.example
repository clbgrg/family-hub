# Family Hub configuration. Copy to .env and fill in. NEVER commit .env.
#   cp .env.example .env

# REQUIRED — Postgres password. There is no default; the app won't start without it.
# Generate a strong one:  openssl rand -base64 24
POSTGRES_PASSWORD=

# REQUIRED — secret that seals login session cookies (min 32 chars). No default.
# Changing it logs everyone out. Generate one:  openssl rand -base64 36
NUXT_SESSION_PASSWORD=

# Timezone (IANA name), used by the calendar. Default: America/Los_Angeles
NUXT_PUBLIC_TZ=America/Los_Angeles

# App log level: error | warn | info | debug. Default: warn
NUXT_PUBLIC_LOG_LEVEL=warn

# Host interface the app binds to:
#   0.0.0.0   = reachable from phones/tablets on your WiFi (default; needed on the Pi)
#   127.0.0.1 = localhost only (hardened; pair with a reverse proxy or Tailscale)
APP_BIND=0.0.0.0
